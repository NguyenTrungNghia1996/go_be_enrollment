APP_NAME="Enrollment System"
APP_ENV=development
APP_PORT=8080
APP_TIMEZONE=Asia/Ho_Chi_Minh

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=enrollment_db
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_PARAMS="charset=utf8mb4&parseTime=True&loc=Local"

JWT_SECRET=super_secret_for_jwt_change_in_production
JWT_EXPIRES_IN=24h

CORS_ALLOW_ORIGINS="*"

# Cloudflare R2 configurations
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
